# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to ~/.env and fill in your actual values
# NEVER commit ~/.env to version control!
#
# Usage:
#   cp ~/Workspace/dotfiles/.env.example ~/.env
#   # Edit ~/.env with your actual secret values
#   # The .zprofile will automatically source ~/.env if it exists

# ============================================
# API KEYS
# ============================================

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# export OPENAI_API_KEY="sk-proj-..."

# Add other API keys here as needed
# export ANTHROPIC_API_KEY="..."
# export GOOGLE_API_KEY="..."

# ============================================
# TOKENS
# ============================================

# GitHub Personal Access Token
# export GITHUB_TOKEN="ghp_..."

# Other tokens
# export HUGGING_FACE_TOKEN="..."

# ============================================
# CREDENTIALS
# ============================================

# Add any other sensitive credentials here
# export AWS_ACCESS_KEY_ID="..."
# export AWS_SECRET_ACCESS_KEY="..."

# ============================================
# NOTES
# ============================================
#
# Security Best Practices:
# 1. Never commit ~/.env to git (it's in .gitignore)
# 2. Use unique API keys per project when possible
# 3. Rotate your keys regularly
# 4. Consider using a password manager or keychain for extra security
# 5. For production systems, use proper secret management tools
#
